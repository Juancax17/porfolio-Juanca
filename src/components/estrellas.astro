---
// StarField.astro
---

<canvas id="starfield" class="absolute inset-0 w-full h-full"></canvas>

<script>
  const canvas = document.getElementById("starfield") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;

  const mouse = { x: canvas.width / 2, y: canvas.height / 2 };

  window.addEventListener("mousemove", (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  const STAR_COUNT = 200;

  const stars = Array.from({ length: STAR_COUNT }, () => ({
    x: Math.random() * canvas.width,
    y: Math.random() * canvas.height,
    z: Math.random() * canvas.width,
    size: Math.random() * 2,
    color: `hsl(${200 + Math.random() * 60}, 100%, ${70 + Math.random() * 30}%)`,
  }));

  function draw() {
    ctx.fillStyle = "rgba(0,0,0,0)";
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    const speedX = (mouse.x - canvas.width / 2) * 0.00005;
    const speedY = (mouse.y - canvas.height / 2) * 0.00005;

    for (const star of stars) {
      star.z -= 1.2;

      if (star.z <= 0) {
        star.x = Math.random() * canvas.width;
        star.y = Math.random() * canvas.height;
        star.z = canvas.width;
      }

      const px = (star.x - canvas.width / 2) / star.z;
      const py = (star.y - canvas.height / 2) / star.z;
      const scale = canvas.width / star.z;

      const screenX = px * canvas.width + canvas.width / 2 + speedX * star.z;
      const screenY = py * canvas.height + canvas.height / 2 + speedY * star.z;

      const radius = Math.max(0.1, scale * star.size);

      // Brillo al acercarse
      const brightness = Math.min(1, (canvas.width - star.z) / canvas.width);

      ctx.beginPath();
      ctx.arc(screenX, screenY, radius, 0, Math.PI * 2);
      ctx.fillStyle = star.color;
      ctx.globalAlpha = brightness;
      ctx.fill();

      // Linea de velocidad (efecto hiperespacio)
      if (brightness > 0.7) {
        const prevPx = (star.x - canvas.width / 2) / (star.z + 2);
        const prevPy = (star.y - canvas.height / 2) / (star.z + 2);
        const prevX = prevPx * canvas.width + canvas.width / 2;
        const prevY = prevPy * canvas.height + canvas.height / 2;

        ctx.beginPath();
        ctx.moveTo(prevX, prevY);
        ctx.lineTo(screenX, screenY);
        ctx.strokeStyle = star.color;
        ctx.globalAlpha = brightness * 0.4;
        ctx.lineWidth = radius * 0.5;
        ctx.stroke();
      }
    }

    ctx.globalAlpha = 1;
    requestAnimationFrame(draw);
  }

  draw();

  window.addEventListener("resize", () => {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  });
</script>