---
// Constellation.astro
---

<canvas id="constellation" class="absolute inset-0 w-full h-full"></canvas>

<script>
  const canvas = document.getElementById("constellation") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;

  const mouse = { x: -1000, y: -1000 };
  const STAR_COUNT = 120;
  const CONNECTION_DISTANCE = 150;
  const MOUSE_DISTANCE = 200;

  window.addEventListener("mousemove", (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  window.addEventListener("mouseleave", () => {
    mouse.x = -1000;
    mouse.y = -1000;
  });

  type Star = {
    x: number;
    y: number;
    vx: number;
    vy: number;
    radius: number;
    color: string;
  };

  const stars: Star[] = Array.from({ length: STAR_COUNT }, () => ({
    x: Math.random() * canvas.width,
    y: Math.random() * canvas.height,
    vx: (Math.random() - 0.5) * 0.4,
    vy: (Math.random() - 0.5) * 0.4,
    radius: Math.random() * 2 + 1,
    color: `hsl(${200 + Math.random() * 80}, 100%, ${70 + Math.random() * 30}%)`,
  }));

  function getDistance(a: { x: number; y: number }, b: { x: number; y: number }) {
    return Math.sqrt((a.x - b.x) ** 2 + (a.y - b.y) ** 2);
  }

  function drawStar(star: Star) {
    // Brillo exterior
    const glow = ctx.createRadialGradient(star.x, star.y, 0, star.x, star.y, star.radius * 4);
    glow.addColorStop(0, star.color);
    glow.addColorStop(1, "transparent");

    ctx.beginPath();
    ctx.arc(star.x, star.y, star.radius * 4, 0, Math.PI * 2);
    ctx.fillStyle = glow;
    ctx.fill();

    // Núcleo
    ctx.beginPath();
    ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
    ctx.fillStyle = "white";
    ctx.fill();
  }

  function drawConnection(a: { x: number; y: number }, b: { x: number; y: number }, alpha: number, color: string) {
    ctx.beginPath();
    ctx.moveTo(a.x, a.y);
    ctx.lineTo(b.x, b.y);

    const gradient = ctx.createLinearGradient(a.x, a.y, b.x, b.y);
    gradient.addColorStop(0, color);
    gradient.addColorStop(1, "rgba(255,255,255,0.1)");

    ctx.strokeStyle = gradient;
    ctx.globalAlpha = alpha;
    ctx.lineWidth = 0.8;
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  function update() {
    for (const star of stars) {
      // Atraccion suave al mouse
      const dx = mouse.x - star.x;
      const dy = mouse.y - star.y;
      const dist = Math.sqrt(dx ** 2 + dy ** 2);

      if (dist < MOUSE_DISTANCE) {
        const force = (MOUSE_DISTANCE - dist) / MOUSE_DISTANCE;
        star.vx += (dx / dist) * force * 0.08;
        star.vy += (dy / dist) * force * 0.08;
      }

      // Friccion para que no aceleren infinito
      star.vx *= 0.98;
      star.vy *= 0.98;

      star.x += star.vx;
      star.y += star.vy;

      // Rebote en bordes
      if (star.x < 0 || star.x > canvas.width) star.vx *= -1;
      if (star.y < 0 || star.y > canvas.height) star.vy *= -1;
    }
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Conexiones entre estrellas
    for (let i = 0; i < stars.length; i++) {
      for (let j = i + 1; j < stars.length; j++) {
        const dist = getDistance(stars[i], stars[j]);
        if (dist < CONNECTION_DISTANCE) {
          const alpha = (1 - dist / CONNECTION_DISTANCE) * 0.6;
          drawConnection(stars[i], stars[j], alpha, stars[i].color);
        }
      }

      // Conexion al mouse
      const distMouse = getDistance(stars[i], mouse);
      if (distMouse < MOUSE_DISTANCE) {
        const alpha = (1 - distMouse / MOUSE_DISTANCE) * 0.8;
        drawConnection(stars[i], mouse, alpha, "#ffffff");
      }
    }

    // Dibujar estrellas encima
    for (const star of stars) {
      drawStar(star);
    }

    // Cursor como estrella brillante
    if (mouse.x > 0) {
      const cursorGlow = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, 20);
      cursorGlow.addColorStop(0, "rgba(255,255,255,0.8)");
      cursorGlow.addColorStop(1, "transparent");

      ctx.beginPath();
      ctx.arc(mouse.x, mouse.y, 20, 0, Math.PI * 2);
      ctx.fillStyle = cursorGlow;
      ctx.fill();

      ctx.beginPath();
      ctx.arc(mouse.x, mouse.y, 3, 0, Math.PI * 2);
      ctx.fillStyle = "white";
      ctx.fill();
    }

    update();
    requestAnimationFrame(draw);
  }

  draw();

  window.addEventListener("resize", () => {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  });
</script>